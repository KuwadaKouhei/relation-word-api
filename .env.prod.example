# --- Deploy target ---
# Caddy が TLS 証明書を自動取得する対象ドメイン。
# 独自ドメインがない場合は EC2 の Public DNS (ec2-xx-xx.ap-northeast-1.compute.amazonaws.com) を使用。
# ただし Let's Encrypt は AWS の *.amazonaws.com には証明書を発行しないので、
# その場合は Caddyfile 内で tls internal に切り替えるか、nip.io / duckdns.org の無料サブドメインを使う。
DOMAIN=api.example.com

# --- App ---
APP_ENV=production
LOG_LEVEL=INFO

# 本番用APIキー。カンマ区切りで複数可。十分に長くランダムな値を使うこと。
# 生成例: openssl rand -hex 32
API_KEYS=CHANGE_ME_TO_A_LONG_RANDOM_STRING

# --- Rate limit ---
RATE_LIMIT_DEFAULT=30/minute

# --- Cache ---
CACHE_TTL_SECONDS=86400

# --- Limits ---
TOP_K_MAX=100
BATCH_MAX=50
